{
  "name": "dinesalida",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@dinesalida/web",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && find . -name node_modules -type d -maxdepth 3 -exec rm -rf {} + 2>/dev/null; true"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "resend": "^6.9.4"
  }
}
