# =============================================================================
# Dine Salida — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values. NEVER commit .env.local to git.
# Run `vercel env pull .env.local` to pull Vercel-provisioned values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Neon Postgres (provisioned by Vercel Neon integration)
# Get from: Vercel Dashboard → Storage → dinesalida-db → .env.local
# Or run: vercel env pull .env.local
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Auth — Admin JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Stripe — Payments & Subscriptions
# Dashboard: https://dashboard.stripe.com/apikeys
# Use sk_test_... for dev, sk_live_... for production
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret
# Dashboard: https://dashboard.stripe.com/webhooks → your endpoint → Signing secret
# Required events: checkout.session.completed, customer.subscription.created,
#   customer.subscription.updated, customer.subscription.deleted,
#   invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Return URL after Stripe Customer Portal session
STRIPE_PORTAL_RETURN_URL=https://dinesalida.com/manage

# -----------------------------------------------------------------------------
# Resend — Transactional Email
# Dashboard: https://resend.com/api-keys
# Must have a verified sending domain at https://resend.com/domains
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@dinesalida.com
CEO_NOTIFY_EMAIL=CEO@epicai.ai

# -----------------------------------------------------------------------------
# App Config
# No trailing slash
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://dinesalida.com
